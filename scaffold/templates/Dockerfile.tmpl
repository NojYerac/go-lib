# ── build stage ───────────────────────────────────────────────────────────────
FROM golang:{{.GoVersion}}-alpine AS builder

WORKDIR /src

# Cache module downloads separately from source compilation.
COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 go build \
    -ldflags="-s -w \
      -X {{.GoLibModule}}/version.semVer=$(cat VERSION 2>/dev/null || echo 0.0.0) \
      -X {{.GoLibModule}}/version.gitSHA=$(git rev-list -1 HEAD 2>/dev/null || echo unknown)" \
    -o /out/{{.Name}} \
    ./cmd/{{.Name}}

# ── runtime stage ─────────────────────────────────────────────────────────────
FROM scratch

COPY --from=builder /out/{{.Name}} /{{.Name}}

# Default: no-TLS, port 8080.  Override at runtime via env vars.
ENV {{.NameUpper}}_NO_TLS=true \
    {{.NameUpper}}_PORT=8080 \
    {{.NameUpper}}_LOG_LEVEL=info \
    {{.NameUpper}}_EXPORTER_TYPE=noop \
    {{.NameUpper}}_HEALTHCHECK_CHECK_INTERVAL=30s

EXPOSE 8080

ENTRYPOINT ["/{{.Name}}"]
